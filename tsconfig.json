{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "preserve",
    "lib": [
      "DOM",
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": []
  },
  "include": [
    "client/**/*.ts",
    "components/**/*.ts",
    "components/**/*.vue",
    "extension.config.ts",
    "server/**/*.ts",
    "types/**/*.d.ts"
  ]
}
